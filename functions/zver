#
# Get version number of a command (wrapper for zinfo -v)
# Use 'zver --help' for more information.

local -A _fn=(
    [info]="Get version number of a command"
    [desc]="Returns the version number of a command. Automatically tries
            --version, -v, -V flags. This is a convenience wrapper for 'zinfo -v'."
    [version]="2.0.0"
    [created]="2026"
    [modified]="2026-02-09"
    [license]="MIT"
    [author]="Andrzej Barabasz"
    [notes]="For full command info, use 'zinfo' directly."
)

local -a _fn_args=(
    "command|Command to get version for|r"
)

local -a _fn_opts=(
    "quiet|q|Only set REPLY, don't print"
)

local -a _fn_examples=(
    "zver git|Show: '2.47.0'"
    "zver python3|Show Python version"
    "zver brew|Show Homebrew version"
)

local -A opts=() args=()
_fn_init "$@" || return $REPLY

local cmd="${args[command]}"
local quiet_opt=""
(( ${+opts[quiet]} )) && quiet_opt="-q"

zinfo -v $quiet_opt "$cmd"
