#
# Find where a command is defined (wrapper for zinfo -p)
# Use 'zwhere --help' for more information.

local -A _fn=(
    [info]="Find where a command is defined"
    [desc]="Returns the path to a binary, function file, or type for aliases/builtins.
            This is a convenience wrapper for 'zinfo -p'."
    [version]="1.0.0"
    [created]="2025"
    [modified]="2026-02-09"
    [license]="MIT"
    [author]="Andrzej Barabasz"
    [notes]="For full command info, use 'zinfo' directly."
)

local -a _fn_args=(
    "command|Command name to locate|r"
)

local -a _fn_opts=(
    "quiet|q|Only set REPLY, don't print"
)

local -a _fn_examples=(
    "zwhere git|Show: '/usr/bin/git'"
    "zwhere appinfo|Show: '/Users/.../.config/zsh/functions/appinfo'"
    "zwhere ls|Show path (resolves alias if needed)"
)

local -A opts=() args=()
_fn_init "$@" || return $REPLY

local cmd="${args[command]}"
local quiet_opt=""
(( ${+opts[quiet]} )) && quiet_opt="-q"

zinfo -p $quiet_opt "$cmd"
