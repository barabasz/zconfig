#
# Display short description of a zconfig function
# Use 'zinfo --help' for more information.

local -A _fn=(
    [info]="Display short description of a zconfig function"
    [desc]="Shows the one-line description of a function from functions/ or lib/.
            For functions using fn.zsh framework, extracts the [info] field.
            For lib helpers, shows the first comment line.
            Use zwhere for location, --help for full documentation."
    [version]="1.0.0"
    [created]="2025"
    [modified]="2026-02-09"
    [license]="MIT"
    [author]="Andrzej Barabasz"
    [notes]="For full help, run the function with --help flag."
)

local -a _fn_args=(
    "function|Function name to look up|r"
)

local -a _fn_examples=(
    "zinfo appinfo|Show: 'Show version and location info for a command'"
    "zinfo printe|Show: 'Print error message to stderr'"
)

local -A opts=() args=()
_fn_init "$@" || return $REPLY

local func_name="${args[function]}"
local zsh_dir="${ZDOTDIR:-${XDG_CONFIG_HOME:-$HOME/.config}/zsh}"
local lib_dir="$zsh_dir/lib"
local func_dir="$zsh_dir/functions"

# Check if it's a function from /functions directory
if [[ -f "$func_dir/$func_name" ]]; then
    local content=$(<"$func_dir/$func_name")

    # Try to extract [info] field from _fn array (fn.zsh framework)
    if [[ "$content" =~ '\[info\]="([^"]+)"' ]]; then
        print "${match[1]}"
        return 0
    fi

    # Fallback: extract description from comments (skip header lines)
    local line
    while IFS= read -r line; do
        [[ "$line" != \#* ]] && break
        line="${line#\#}"
        line="${line# }"
        # Skip empty lines and "Part of zconfig" header
        [[ -z "$line" || "$line" == "Part of zconfig"* ]] && continue
        # Skip "Use ... --help" lines
        [[ "$line" == "Use '"*"' --help"* ]] && continue
        # Found the description
        print "$line"
        return 0
    done < "$func_dir/$func_name"

    printe "No description found for '$func_name'"
    return 1
fi

# Search in /lib directory
local file line
local -a comment_block=()

for file in "$lib_dir"/*.zsh(.N); do
    comment_block=()

    while IFS= read -r line; do
        if [[ "$line" =~ "^${func_name}\\s*\\(\\)" ]]; then
            # Found the function - print first non-empty comment
            for cmt in "${comment_block[@]}"; do
                cmt="${cmt#\#}"
                cmt="${cmt# }"
                [[ -n "$cmt" ]] && { print "$cmt"; return 0; }
            done
            printe "No description found for '$func_name'"
            return 1
        elif [[ "$line" == \#* ]]; then
            comment_block+=("$line")
        else
            comment_block=()
        fi
    done < "$file"
done

printe "Function '$func_name' not found"
return 1
